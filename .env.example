APP_ENV=development
APP_ADDR=:8080
APP_BASE_URL=http://localhost:8080
DATABASE_URL=postgres://secureshare:secureshare@postgres:5432/secureshare?sslmode=disable
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_TRANSIT_KEY=secureshare
SECURESHARE_ADMIN_API_KEY=change-me
LEGACY_ADMIN_API_KEY_ENABLED=true
TOKEN_HMAC_PEPPER=replace-with-a-long-random-value-at-least-32-bytes
SESSION_SECRET=replace-with-a-long-random-value-at-least-32-bytes
CSRF_SECRET=replace-with-a-long-random-value-at-least-32-bytes
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now
REQUEST_IP_HASH_PEPPER=replace-with-a-long-random-value-at-least-32-bytes
MAX_SECRET_TTL=168h
DEFAULT_SECRET_TTL=24h
CONSUMING_LEASE_TTL=30s
CLEANUP_INTERVAL=5m
CONSUMED_PAYLOAD_RETENTION=0m
EXPIRED_PAYLOAD_RETENTION=24h
REVOKED_PAYLOAD_RETENTION=24h
AUDIT_EVENT_RETENTION=2160h
SESSION_TTL=12h
SESSION_IDLE_TIMEOUT=30m
COOKIE_SECURE=false
MAX_SECRET_BYTES=32768
LOG_LEVEL=info
METRICS_ENABLED=true
OPENAPI_PUBLIC=false
SWAGGER_UI_ENABLED=true
DEVELOPER_EMAIL_DELIVERY_ENABLED=true

# SMTP credentials are managed through /admin/settings/email and encrypted with Vault Transit.
# These values document local/test defaults and built-in email limits; do not put real SMTP secrets here.
SMTP_FEATURE_ENABLED=true
EMAIL_MAX_SUBJECT_BYTES=255
EMAIL_MAX_MESSAGE_BYTES=10240
EMAIL_MAX_FOOTER_BYTES=2048
EMAIL_DELIVERY_TIMEOUT=10s
EMAIL_CONNECTION_TIMEOUT=5s
EMAIL_RETRY_RATE_LIMIT=5
TEST_SMTP_ENABLED=true
